# ========================================
# アプリケーション設定
# ========================================
# Auth.js v5 はAUTH_SECRETを使用 (NEXTAUTH_SECRETも後方互換)
# openssl rand -base64 32 で生成
NEXTAUTH_SECRET=your-nextauth-secret-here
AUTH_URL=https://your-deployment.pages.dev  # 本番URLに変更

# ========================================
# Google OAuth & Calendar API
# ========================================
# Google Cloud Console で取得
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ========================================
# データベース (Prisma Accelerate 経由)
# ========================================
# Cloudflare Pages / Edge Runtime で動作するには Prisma Accelerate が必要です。
#
# セットアップ手順:
# 1. https://console.prisma.io/ で無料アカウントを作成
# 2. 新しいプロジェクトを作成し、既存のデータベース接続文字列を貼り付け
# 3. 「Enable Accelerate」をクリック
# 4. 発行された接続文字列 (prisma://...) を DATABASE_URL に設定
#
# 本番環境 (Cloudflare Pages):
DATABASE_URL="prisma://accelerate.prisma-data.net/?api_key=your_api_key"

# マイグレーション用の直接接続 (prisma migrate / prisma db push で使用)
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ========================================
# ローカル開発
# ========================================
# ローカル開発では DATABASE_URL に直接接続URLを使用することもできます。
# ただし Cloudflare Pages へのデプロイ時は Prisma Accelerate URL が必要です。

# ========================================
# Resend (メール通知 - オプション)
# ========================================
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com
